# ============================================
# HomeValue AI - Environment Variables
# ============================================
# Copy this file to .env and fill in local secrets.
# Never commit .env.

# ---- Valuation API ----
VALUATION_DB_PATH=data/market.sqlite
VALUATION_CONFIG_PATH=config/projects.yaml
VALUATION_HOST=127.0.0.1
VALUATION_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=2707
FRONTEND_PROXY_API_BASE=http://127.0.0.1:1108
RATE_LIMIT_VALUATION_REQUESTS=120
RATE_LIMIT_VALUATION_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_LOGIN_REQUESTS=20
RATE_LIMIT_AUTH_REGISTER_REQUESTS=10
# Optional. If unset, the server creates .runtime/auth_secret.key automatically.
# AUTH_SECRET_KEY=
AUTH_TOKEN_TTL_HOURS=168
# Set this before enabling manual verified transaction writes.
# ADMIN_API_KEY=
VALUATION_RELOAD=0
VALUATION_STORAGE_BACKEND=auto
VALUATION_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://c2-app-134.solanai.us,https://solanai.us,https://www.solanai.us

# ---- MBBank / VietQR Payments ----
# MBBank account receiving payments. Do not commit real credentials.
MBBANK_BANK_BIN=970422
MBBANK_ACCOUNT_NO=
MBBANK_ACCOUNT_NAME=
MBBANK_USERNAME=
MBBANK_PASSWORD=
MBBANK_TIMEOUT_SECONDS=20
PAYMENT_AGENT_PRO_AMOUNT_VND=299000
PAYMENT_CREDIT_PACK_AMOUNT_VND=50000
PAYMENT_CREDIT_PACK_CREDITS=100
PAYMENT_ORDER_EXPIRES_MINUTES=30
AGENT_PRO_DAYS=30
VIETQR_TEMPLATE=compact2

# ---- Storage ----
# auto: use MongoDB when MONGODB_URI exists, otherwise SQLite
# sqlite: force data/market.sqlite
# mongo: require MONGODB_URI
MONGODB_URI=
MONGODB_DB=homevalue_market

# ---- Optional LLM Answer Rewriter ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.yescale.io/v1
MODEL=grok-4-1-fast-reasoning
VALUATION_LLM_ENABLED=0
OPENAI_TIMEOUT_SECONDS=8
OPENAI_TEMPERATURE=0.55
OPENAI_MAX_TOKENS=220

# ---- Advisor / Entitlement Flags ----
ENABLE_ADVISOR_PROMPT_V2=1
ENABLE_PLAN_ENTITLEMENTS=1
ENABLE_AUTO_MAP_ENRICHMENT=1
ENABLE_NEWS_SEARCH=1
ENABLE_PRO_OUTLOOK=1
ENABLE_PRO_PDF=1
ENABLE_DEBUG_CONTEXT_RESPONSE=0
BASIC_VALUATION_CREDIT_COST=1
BASIC_MANUAL_MAP_CREDIT_COST=2

# ---- Optional Google Maps / Places ----
# Enables real POI names and ratings for amenity advice.
# Prefer SerpApi Google Maps because it returns Google Maps place_results/local_results.
SERPAPI_API_KEY=
SERPAPI_TIMEOUT_SECONDS=10
MAPS_ENRICHMENT_CACHE_TTL_SECONDS=1800
# Optional direct Google Places fallback.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_TIMEOUT_SECONDS=3

# ---- Optional News Search Enrichment ----
# News uses Google News RSS plus map geocoding for Pro nearby-event verification.
NEWS_SEARCH_TIMEOUT_SECONDS=6
NEWS_CACHE_TTL_SECONDS=1800
NEWS_NEARBY_RADIUS_KM=8
NEWS_GEO_MAX_CANDIDATES=4

# ---- Prompt Files ----
VALUATION_PROMPT_DIR=prompts
VALUATION_SYSTEM_PROMPT_PATH=
VALUATION_USER_PROMPT_PATH=
VALUATION_FALLBACK_PROMPT_PATH=
VALUATION_INTENT_RULES_PATH=

# ---- AI Hook Logging (provided by instructor) ----
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=f3p1dEOhD_z8qjjtbeCtb2t9ASMEliz-4juZfWe3ZPgCtPZp-LjWthBfeNU8d5dP
AI_LOG_DIR=.ai-log
