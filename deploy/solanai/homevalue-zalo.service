[Unit]
Description=HomeValue AI Zalo bot
After=network.target homevalue-api.service
Wants=homevalue-api.service

[Service]
WorkingDirectory=/home/anonymous/VINUNI/buildphase/C2-App-134/zalo
Environment=NODE_ENV=production
Environment=API_BASE=http://127.0.0.1:8000
Environment=CHAT_PATH=/zalo/chat
